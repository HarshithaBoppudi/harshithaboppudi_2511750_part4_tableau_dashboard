      <aliases enabled='yes' />
      <column caption='Cost' datatype='real' name='[Calculation_0726518957645825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales]-[profit]' />
      </column>
      <column caption='Profit margin' datatype='real' name='[Calculation_0726518958329858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0726518958587907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([sales])/ COUNTD([order_id])' />
      </column>
      <column caption='Shipping delay bucket' datatype='string' name='[Calculation_0726518959407110]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;0-2 days (Fast)&quot; ELSEIF [delivery_days] &lt;= 4 THEN &quot;3-4 days (Standard)&quot; ELSEIF [delivery_days] &lt;= 6 THEN &quot;5-6 days (Slow)&quot; ELSE &quot;7+ days (Critical)&quot; END' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0726518980378631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag])/COUNTD([order_id])' />
      </column>
